IDR_MENU_TREE_ALL MENU
BEGIN
    POPUP "ЩшБИВйзї"
    BEGIN
        MENUITEM "ЬэМгЩшБИ",                        ID_MENU_DEVICE_ADD
    END
END

IDR_MENU_DEVICE MENU
BEGIN
    POPUP "device oper"
    BEGIN
        MENUITEM "ЕЧТМ",                          ID_MENU_RELOGIN
        MENUITEM "зЂЯњ",                          ID_MENU_LOGOUT
        MENUITEM "ЩОГ§",                          ID_MENU_DEVICE_DELETE
        MENUITEM SEPARATOR
        MENUITEM "Ъєад",                          ID_MENU_DEVICE_INFO
    END
END

IDR_MENU_PRESET MENU
BEGIN
    POPUP "Preset"
